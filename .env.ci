# CI-only env for the e2e playwright job. Contains only fake values — no
# real secrets. Copied over `.env` by .github/workflows/ci.yml before the
# agent is booted against fake-deps.

# Route the agent at fake-deps for every outbound integration.
SLACK_API_BASE_URL=http://localhost:13765/slack/api
GITHUB_API_BASE_URL=http://localhost:13765/github/api
LANGSMITH_HOST_API_URL=http://localhost:13765/langsmith

# Fake Slack credentials — signing secret must match hack/fake_deps/slack.py.
SLACK_BOT_TOKEN=xoxb-fake
SLACK_SIGNING_SECRET=dev-secret
SLACK_BOT_USER_ID=BOPENSWE01
SLACK_BOT_USERNAME=openswe-bot

# Fake GitHub App — a throwaway RSA key pair lives at .github/ci/ so
# jwt.encode succeeds; fake-deps does not verify the signature.
GITHUB_APP_ID=1
GITHUB_APP_INSTALLATION_ID=1
GITHUB_APP_PRIVATE_KEY_PATH=.github/ci/fake_github_app_key.pem
GITHUB_WEBHOOK_SECRET=dev-secret

# Dev-only Fernet key, committed intentionally.
TOKEN_ENCRYPTION_KEY=L39uBI-jBM7bKORuhozJgS6Rr-x-e2hHq4w3Z8eYW2U=

# Options exercised by the e2e suite.
OPENSWE_OPTIONS=nofixedrepo,slackv2,allowanyghuser

# Force bot-token-only auth mode so webhooks don't try to resolve per-user
# GitHub OAuth tokens via LangSmith (which isn't reachable in CI). See
# agent/utils/auth.py::is_bot_token_only_mode.
LANGSMITH_API_KEY_PROD=fake-ci-key

# Force the local-process sandbox backend; no Docker/Daytona in CI.
SANDBOX_TYPE=local

# Point the agent at the in-memory langgraph dev server.
LANGGRAPH_URL=http://localhost:2025
